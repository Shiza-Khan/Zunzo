{
  "extends": ["development"],
  "hints": {
    "no-inline-styles": "off",
    "axe/text-alternatives": "off",
    "axe/structure": [
      "default",
      {
        "listitem": "off"
      }
    ],
    "button-type": "off",
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off"
      }
    ],
    "typescript-config/consistent-casing": "off",
    "typescript-config/strict": "off",
    "axe/parsing": [
      "default",
      {
        "duplicate-id-active": "off"
      }
    ]
  }
}
